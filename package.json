{
  "name": "@tgraph/backend-generator",
  "version": "0.1.1",
  "description": "CLI toolkit for generating NestJS APIs, DTOs, and React Admin dashboards from Prisma schemas.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tgraph": "dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:watch": "concurrently \"tsc -p tsconfig.json --watch\" \"tsc-alias -p tsconfig.json --watch\"",
    "package": "npm run build && rimraf package && npm pack && node -e \"const fs=require('fs'); const f=fs.readdirSync('.').find(x=>x.endsWith('.tgz')); fs.mkdirSync('package',{recursive:true}); require('child_process').execSync(`tar -xzf ${f} -C package`)\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "test": "jest",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "docs:preview": "cd docs && npm run preview"
  },
  "author": "Mohamed Elbaz",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bazokhan/backend-generator.git"
  },
  "bugs": {
    "url": "https://github.com/bazokhan/backend-generator/issues"
  },
  "homepage": "https://github.com/bazokhan/backend-generator#readme",
  "keywords": [
    "prisma",
    "nestjs",
    "react-admin",
    "code-generator",
    "crud",
    "typescript",
    "cli"
  ],
  "peerDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@types/express": "^5.0.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@nestjs/common": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.1",
    "@swc/core": "^1.15.1",
    "@swc/jest": "^0.2.36",
    "@types/express": "*",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.0",
    "concurrently": "^9.2.1",
    "esbuild-register": "^3.6.0",
    "express": "*",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.0",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
